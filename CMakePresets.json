{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dp-gcc-ninja",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MESSAGE_LOG_LEVEL": "NOTICE"
      }
    },
    {
      "name": "dp-win32-rk4-sdl-debug",
      "displayName": "Windows GCC RK4 SDL Debug",
      "inherits": "dp-gcc-ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "binaryDir": "${sourceDir}/.build/dp-win32-rk4-sdl-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DP_PLATFORM": "win32",
        "DP_INTEGRATOR": "rk4",
        "DP_RENDERER": "sdl"
      }
    },
    {
      "name": "dp-win32-rk4-sdl-release",
      "displayName": "Windows GCC RK4 SDL Release",
      "inherits": "dp-gcc-ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "binaryDir": "${sourceDir}/.build/dp-win32-rk4-sdl-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DP_PLATFORM": "win32",
        "DP_INTEGRATOR": "rk4",
        "DP_RENDERER": "sdl"
      }
    },
    {
      "name": "dp-posix-rk4-sdl-debug",
      "displayName": "Linux GCC RK4 SDL Debug",
      "inherits": "dp-gcc-ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "binaryDir": "${sourceDir}/.build/dp-posix-rk4-sdl-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DP_PLATFORM": "posix",
        "DP_INTEGRATOR": "rk4",
        "DP_RENDERER": "sdl"
      }
    },
    {
      "name": "dp-posix-rk4-sdl-release",
      "displayName": "Linux GCC RK4 SDL Release",
      "inherits": "dp-gcc-ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "binaryDir": "${sourceDir}/.build/dp-posix-rk4-sdl-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DP_PLATFORM": "posix",
        "DP_INTEGRATOR": "rk4",
        "DP_RENDERER": "sdl"
      }
    }
  ],
  "buildPresets": [
    {
