  "configurePresets": [
    {
      "name": "gcc-ninja",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MESSAGE_LOG_LEVEL": "NOTICE"
      }
    },
    {
      "name": "win32-rk4-sdl-debug",
      "displayName": "Windows GCC RK4 SDL Debug | .\\.build\\win32-rk4-sdl-debug\\bin\\DoublePendulum.exe",
      "inherits": "gcc-ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "binaryDir": "${sourceDir}/.build/win32-rk4-sdl-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DP_PLATFORM": "win32",
        "DP_INTEGRATOR": "rk4",
        "DP_RENDERER": "sdl"
      }
    },
